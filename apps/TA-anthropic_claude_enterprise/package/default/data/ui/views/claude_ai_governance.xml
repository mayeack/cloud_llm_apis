<form version="1.1" theme="dark">
  <label>Claude Enterprise - Governance</label>
  <description>Directory, project, conversation, and data-movement governance from the Anthropic Compliance API. Index scope comes from the anthropic_claude_index macro.</description>
  <fieldset submitButton="false">
    <input type="time" token="time">
      <label>Time Range</label>
      <default>
        <earliest>-14d@d</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>Synced Users</title>
      <single>
        <search>
          <query>`anthropic_claude_index` sourcetype="anthropic:compliance:user" | stats dc(id) AS users</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </single>
    </panel>
    <panel>
      <title>Synced Groups</title>
      <single>
        <search>
          <query>`anthropic_claude_index` sourcetype="anthropic:compliance:group" | stats dc(id) AS groups</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </single>
    </panel>
    <panel>
      <title>Project Events</title>
      <single>
        <search>
          <query>`anthropic_claude_index` sourcetype="anthropic:compliance:activity" event_type=project_* | stats count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </single>
    </panel>
    <panel>
      <title>User Invites</title>
      <single>
        <search>
          <query>`anthropic_claude_index` sourcetype="anthropic:compliance:activity" event_type=org_user_invite_* | stats count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </single>
    </panel>
    <panel>
      <title>Data Exports</title>
      <single>
        <search>
          <query>`anthropic_claude_index` sourcetype="anthropic:compliance:activity" event_type=org_data_export_* | stats count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </single>
    </panel>
  </row>
  <row>
    <panel>
      <title>Project Lifecycle Events</title>
      <chart>
        <search>
          <query>`anthropic_claude_index` sourcetype="anthropic:compliance:activity" event_type=project_* | timechart count by event_type</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.chart.stackMode">stacked</option>
      </chart>
    </panel>
    <panel>
      <title>Project Visibility Changes</title>
      <table>
        <search>
          <query>`anthropic_claude_index` sourcetype="anthropic:compliance:activity" event_type="project_visibility_changed" | table _time, actor_email, claude_project_id, visibility | sort - _time</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <title>User Invite Lifecycle</title>
      <chart>
        <search>
          <query>`anthropic_claude_index` sourcetype="anthropic:compliance:activity" event_type=org_user_invite_* | stats count by event_type | sort event_type</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">bar</option>
      </chart>
    </panel>
    <panel>
      <title>Data Export Activity</title>
      <table>
        <search>
          <query>`anthropic_claude_index` sourcetype="anthropic:compliance:activity" event_type=org_data_export_* | table _time, event_type, actor_email, organization_id | sort - _time</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <title>Conversation Events</title>
      <table>
        <search>
          <query>`anthropic_claude_index` sourcetype="anthropic:compliance:activity" (event_type=conversation_* OR event_type=claude_chat_*) | stats count by event_type, actor_email | sort - count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </table>
    </panel>
    <panel>
      <title>File Uploads</title>
      <table>
        <search>
          <query>`anthropic_claude_index` eventtype=anthropic_claude_file_events event_type=*_uploaded | stats count values(file_id) AS files by actor_email | sort - count | head 20</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <title>Directory Snapshot (Users)</title>
      <table>
        <search>
          <query>`anthropic_claude_index` sourcetype="anthropic:compliance:user" | sort - _time | dedup id | table email, full_name, organization_role, id</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </table>
    </panel>
    <panel>
      <title>Directory Snapshot (Groups)</title>
      <table>
        <search>
          <query>`anthropic_claude_index` sourcetype="anthropic:compliance:group" | sort - _time | dedup id | table name, description, source_type, roles, id</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <title>Memory Governance</title>
      <table>
        <search>
          <query>`anthropic_claude_index` sourcetype="anthropic:compliance:activity" event_type=platform_memory_* | stats count by event_type, actor_email | sort - count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </table>
    </panel>
    <panel>
      <title>Invite Link Hygiene</title>
      <table>
        <search>
          <query>`anthropic_claude_index` sourcetype="anthropic:compliance:activity" event_type=org_invite_link_* | table _time, event_type, actor_email | sort - _time</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </table>
    </panel>
    <panel>
      <title>MCP &amp; Integrations Activity</title>
      <table>
        <search>
          <query>`anthropic_claude_index` sourcetype="anthropic:compliance:activity" (event_type=mcp_* OR event_type=extension_* OR event_type=integration_*) | stats count by event_type, actor_email | sort - count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </table>
    </panel>
  </row>
</form>
