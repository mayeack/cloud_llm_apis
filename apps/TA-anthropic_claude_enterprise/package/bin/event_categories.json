{
  "version": 1,
  "vendor": "anthropic",
  "_comment": "Ordered first-match-wins glob rules mapping Anthropic activity event_type onto the ai.* vocabularies (docs/ai-schema.md). New event types are a data-only patch here — no code change. Rule ORDER is significant: authentication, then data-export, then read-only access, then content families, then admin-change families, then default.",
  "category_rules": [
    ["user_signed_in_*", "authentication"],
    ["user_signed_out", "authentication"],
    ["sso_login_initiated", "authentication"],
    ["compliance_api_accessed", "data_export"],
    ["*data_export*", "data_export"],
    ["*_viewed", "content_access"],
    ["*_accessed", "content_access"],
    ["*_listed", "content_access"],
    ["claude_file_*", "content_access"],
    ["file_*", "content_access"],
    ["claude_chat_*", "content_access"],
    ["conversation_renamed", "admin_change"],
    ["conversation_deleted", "admin_change"],
    ["user_name_changed", "admin_change"],
    ["*api_key_*", "admin_change"],
    ["*_role_updated", "admin_change"],
    ["claude_code_*_updated", "admin_change"],
    ["org_*", "admin_change"],
    ["project_*", "admin_change"],
    ["rbac_*", "admin_change"],
    ["group_*", "admin_change"],
    ["platform_memory_*", "admin_change"],
    ["mcp_*", "admin_change"],
    ["integration_*", "admin_change"],
    ["extension_*", "admin_change"],
    ["billing_*", "admin_change"]
  ],
  "default_category": "usage",
  "action_rules": [
    ["user_signed_in_*", "login"],
    ["user_signed_out", "logout"],
    ["sso_login_initiated", "login_attempt"],
    ["*_requested", "request"],
    ["*_viewed", "read"],
    ["*_accessed", "read"],
    ["*_listed", "read"],
    ["*data_export*", "export"],
    ["*_exported", "export"],
    ["*_deleted", "delete"],
    ["*_revoked", "delete"],
    ["*_removed", "delete"],
    ["*_created", "create"],
    ["*_generated", "create"],
    ["*_sent", "create"],
    ["*_installed", "create"],
    ["*_added", "create"],
    ["*_started", "create"],
    ["*_uploaded", "create"],
    ["*_updated", "update"],
    ["*_changed", "update"],
    ["*_renamed", "update"],
    ["*_toggled", "update"],
    ["*_verified", "update"],
    ["*_activated", "update"],
    ["*_deactivated", "update"],
    ["*_assigned", "update"],
    ["*_accepted", "update"],
    ["*_disabled", "update"],
    ["*_enabled", "update"]
  ],
  "default_action": "unknown",
  "resource_rules": [
    ["project*", "project"],
    ["*api_key*", "api_key"],
    ["org_sso*", "identity"],
    ["org_jit*", "identity"],
    ["org_domain*", "identity"],
    ["sso_login_initiated", "identity"],
    ["org_user*", "user"],
    ["*_role_*", "user"],
    ["rbac*", "user"],
    ["group*", "user"],
    ["user_name_changed", "user"],
    ["claude_chat*", "chat"],
    ["conversation*", "chat"],
    ["*file*", "file"],
    ["platform_memory*", "memory"],
    ["mcp*", "integration"],
    ["integration*", "integration"],
    ["extension*", "integration"],
    ["org_*", "org"]
  ],
  "default_resource": "other",
  "outcome_rules": [
    ["*_failed", "failure"],
    ["*_denied", "failure"],
    ["*_rejected", "failure"],
    ["*_blocked", "failure"]
  ],
  "default_outcome": "success"
}
