# Example local/inputs.conf for TA-cloud_llm_apis.
# Copy into local/inputs.conf, set a real api_key, and set disabled = 0.

[anthropic_compliance_activity://prod_compliance]
disabled = 0
api_key = sk-ant-REPLACE-ME
base_url = https://api.anthropic.com
index = cloud_llm_apis
interval = 60
initial_lookback_minutes = 1440
redact_actor_email = true

[anthropic_admin_usage://prod_admin]
disabled = 0
api_key = sk-ant-admin-REPLACE-ME
index = cloud_llm_apis
interval = 300
bucket_width = 1h

[anthropic_enterprise_analytics://prod_enterprise]
disabled = 0
api_key = sk-ant-REPLACE-ME
index = cloud_llm_apis
interval = 3600
collect_engagement_users = false
